<section class="ui center aligned middle aligned segment">
    <h2>Add New Gallery</h2>
    <form class="ui stacked segment form" action="/galleries/addGallery" method="POST">
        <div class="three fields">
            <div class="field">
                <label>Title</label>
                <input placeholder="Title" type="text" name="title" autofocus required>
            </div>
            <div class="field">
                <label>Photographer</label>
                <input placeholder="Photographer" type="text" name="photographer" required>
            </div>
            <div class="field">   
                <label>Rating</label>
                <input placeholder="Rating (1-5)" type="number" name="rating" min="1" max="5">
            </div>
        </div>
        <button class="ui blue submit button">Add Gallery</button>
    </form>
</section>