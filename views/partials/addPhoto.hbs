<form class="ui stacked segment form" action="/playlist/{{id}}/addsong" method="POST">
    <div class="two fields">
        <div class="field">
            <label>Title</label>
            <input type="text" name="title" autofocus required title="Please include a valid Title" placeholder="Title">
        </div>
        <div class="field">
            <label>Photographer</label>
            <input type="text" name="photographer" required title="Please include a valid Photographer" placeholder="Photographer">
        </div>
        <div class="field">
            <label>Image</label>
            <input type="file" name="image" required title="Please include a valid URL" placeholder="image">
        </div>
    </div>
    <button class="ui blue submit button">Add Gallery</button>
</form>