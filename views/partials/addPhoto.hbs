
<form class="ui centered segment form" action="/gallery/{{id}}/addPhoto" method="POST">
    <div class="two fields">
        <div class="field">
            <label>Title</label>
            <input type="text" name="title" autofocus required title="Please include a valid Title" placeholder="Title">
        </div>

        <div class="field">
            <label>Image</label>
            <input type="text" name="image" required title="Please include a valid URL" placeholder="image">
        </div>
    </div>
    <button class="ui blue submit button">Add Photo</button>
</form>