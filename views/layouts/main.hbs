{{!--
    Main layout template.
    Serves as the base HTML structure for all pages in the Photo Gallery App.
    All views are injected into the {{{body}}} placeholder.
--}}

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="https://glitch.com/favicon.ico" /> {{!-- Set the Glitch favicon for the app --}}
    <title>{{title}}</title> {{!-- Dynamically set the page title from the view data --}}

    {{!-- Import the Fomantic UI stylesheet for consistent UI components and styling --}}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fomantic-ui/2.9.4/semantic.min.css">

    {{!-- Import the app's custom stylesheet --}}
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <section class="ui container">
        {{{body}}} {{!-- Inject the rendered view content into the layout --}}
    </section>

    {{!-- Import jQuery, required by Fomantic UI components --}}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
        integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    {{!-- Import the Fomantic UI JavaScript for interactive UI components --}}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fomantic-ui/2.9.4/semantic.min.js"></script>

    {{!-- Import the app's custom JavaScript file --}}
    <script src="/script.js"></script>
</body>

</html>