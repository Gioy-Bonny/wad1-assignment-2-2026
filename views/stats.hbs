{{> menu id="stats"}}

<section class="ui center aligned middle aligned segment">

    <h2>Gallery App Statistics</h2>

    <h3 class="ui header">
        App Statistics
    </h3>
    <p>
        The gallery app now contains:
    </p>
    {{#with stats}}
    <div class="ui center aligned grid">

        <div class="ui sixteen wide column">

            <div class="ui centered three statistics">
                <div class="ui statistic">
                    <div class="value">
                        <i class="photo video icon"></i>
                    </div>
                    <div class="label">
                        {{displayNumGalleries}} galleries
                    </div>
                </div>

                <div class="ui red statistic">
                    <div class="value">
                        <i class="camera icon"></i>
                    </div>
                    <div class="label">
                        {{displayNumPhotos}} photos
                    </div>
                </div>

                <div class="ui blue statistic">
                    <div class="value">
                        <i class="balance scale icon"></i>
                    </div>
                    <div class="label">
                        Average photos per <br> gallery: {{displayAverage}}
                    </div>
                </div>

            </div>
        </div>
    </div>
    {{/with}}
</section>