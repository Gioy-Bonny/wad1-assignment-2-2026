{{> welcomemenu id="signup"}}

<form class="ui stacked centered segment form" action="/register" method="POST"
    style="background-color: #1A1D24; padding: 30px; border-radius: 10px; margin-top: 50px; width: 700px; margin-left: auto; margin-right: auto;">
    <h3 class="ui header">Register</h3>
            {{#if error}}
            <div class="ui red message">{{error}}</div>
            {{/if}}    
            <div class="two fields">
        <div class="field">
            <label for="firstName">First Name</label>
            <input placeholder="First Name" type="text" name="firstName" autofocus required>
        </div>
        <div class="field">
            <label for="lastName">Last Name</label>
            <input placeholder="Last Name" type="text" name="lastName" required>
        </div>
    </div>
    <div class="field">
        <label for="email">Email</label>
        <input placeholder="Email" type="text" name="email" required>
    </div>
    <div class="field">
        <label for="password">Password</label>
        <input placeholder="Password" type="password" name="password" required>
    </div>
    <div class="center aligned field" style="margin-top: 20px; text-align: center; padding: 30px;">
        <button class="ui blue submit button">Sign Up</button>
    </div>
    <div class="ui centered column grid" style="margin-top: 20px;">
        <a class="ui secondary button" href="/">Back to Login</a>
    </div>
</form>