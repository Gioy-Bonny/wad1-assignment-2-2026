{{!--
    Galleries Dashboard page view.
    Displays all available photo galleries, each showing the title, photographer,
    photo count, and a link to view the full gallery.
--}}

{{> menu id="dashboard"}} {{!-- Render the shared navigation menu partial with the dashboard ID --}}

<section class="ui center aligned middle aligned segment">
    <h2>Photo Gallery Dashboard</h2>
    <p>
        Photo galleries will be displayed here
    </p>
</section>

<div id="galleries">

    {{!-- Display a message if no galleries exist in the store --}}
    {{#unless galleries}}
    <h1 class="ui center aligned header" id="no_galleries">Create galleries!</h1>
    {{/unless}}

    {{!-- Iterate over each gallery in the galleries collection --}}
    {{#each galleries}}

    {{!-- Only render a gallery section if it contains at least one photo --}}
    {{#if photos.length}}
    <section class="ui center aligned segment" id="gallery">
        <h1>
            {{title}} {{!-- Display the gallery title --}}
        </h1>
        <h3>
            <p>Photographer: {{photos.0.photographer}}</p> {{!-- Display the photographer from the first photo --}}
        </h3>
        <h4>
            {{photos.length}} photos {{!-- Display the total number of photos in the gallery --}}
        </h4>
        <a href="/gallery/{{id}}"> View </a> {{!-- Link to the individual gallery page using its ID --}}
    </section>
    {{/if}}

    {{/each}}

</div>